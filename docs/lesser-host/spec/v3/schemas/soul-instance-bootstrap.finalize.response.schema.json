{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://lesser.host/spec/v3/schemas/soul-instance-bootstrap.finalize.response.schema.json",
  "title": "Instance-key soul bootstrap finalize response",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "agent_id", "agent", "published_version", "publication"],
  "$defs": {
    "publication": {
      "type": "object",
      "additionalProperties": false,
      "required": ["agent_id", "published_version"],
      "properties": {
        "agent_id": { "type": "string", "pattern": "^0x[0-9a-fA-F]{64}$" },
        "published_version": { "type": "integer", "minimum": 1 },
        "registration_uri": { "type": "string", "minLength": 1, "maxLength": 2048, "pattern": "^s3://[^/]+/registry/v1/agents/0x[0-9a-fA-F]{64}/registration\\.json$" },
        "registration_s3_key": { "type": "string", "minLength": 1, "maxLength": 1024, "pattern": "^registry/v1/agents/0x[0-9a-fA-F]{64}/registration\\.json$" },
        "versioned_registration_uri": { "type": "string", "minLength": 1, "maxLength": 2048, "pattern": "^s3://[^/]+/registry/v1/agents/0x[0-9a-fA-F]{64}/versions/[1-9][0-9]*/registration\\.json$" },
        "versioned_registration_s3_key": { "type": "string", "minLength": 1, "maxLength": 1024, "pattern": "^registry/v1/agents/0x[0-9a-fA-F]{64}/versions/[1-9][0-9]*/registration\\.json$" },
        "authority_model": { "type": "string", "enum": ["wallet_principal", "instance_trust"] },
        "anchor_state": { "type": "string", "enum": ["hosted_offchain", "immutable_onchain"] },
        "published_at": { "type": "string", "format": "date-time" }
      }
    },
    "promotion": {
      "type": "object",
      "additionalProperties": false,
      "required": ["agent_id"],
      "properties": {
        "agent_id": { "type": "string", "pattern": "^0x[0-9a-fA-F]{64}$" },
        "registration_id": { "type": "string", "minLength": 1, "maxLength": 256 },
        "stage": {
          "type": "string",
          "enum": ["requested", "approved", "minted", "reviewing", "ready_to_finalize", "graduated"]
        },
        "request_status": { "type": "string", "enum": ["requested", "verified", "minted", "graduated"] },
        "review_status": {
          "type": "string",
          "enum": ["not_started", "conversation_in_progress", "draft_ready", "published"]
        },
        "readiness_status": {
          "type": "string",
          "enum": ["awaiting_verification", "awaiting_mint", "ready_for_conversation", "ready_for_finalize", "graduated"]
        },
        "authority_model": { "type": "string", "enum": ["wallet_principal", "instance_trust"] },
        "anchor_state": { "type": "string", "enum": ["hosted_offchain", "immutable_onchain"] },
        "latest_conversation_id": { "type": "string", "minLength": 1, "maxLength": 128 },
        "latest_conversation_status": { "type": "string", "enum": ["in_progress", "completed", "failed"] },
        "published_version": { "type": "integer", "minimum": 1 },
        "graduated_at": { "type": "string", "format": "date-time" }
      }
    }
  },
  "properties": {
    "version": { "type": "string", "const": "1" },
    "agent_id": { "type": "string", "pattern": "^0x[0-9a-fA-F]{64}$" },
    "agent": { "$ref": "soul-agent-identity.schema.json" },
    "published_version": { "type": "integer", "minimum": 1 },
    "publication": { "$ref": "#/$defs/publication" },
    "promotion": { "$ref": "#/$defs/promotion" }
  }
}
