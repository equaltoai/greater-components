{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://lesser.host/spec/v3/schemas/soul-x402-invocation-grant.consume.response.schema.json",
  "title": "POST /api/v1/soul/x402/grants/{grantId}/consume response",
  "type": "object",
  "additionalProperties": false,
  "required": ["accepted", "replayed", "grant", "usage"],
  "properties": {
    "accepted": { "type": "boolean", "const": true },
    "replayed": { "type": "boolean" },
    "grant": { "$ref": "soul-x402-invocation-grant.schema.json" },
    "usage": {
      "type": "object",
      "additionalProperties": false,
      "required": ["slot", "idempotencyKeyHash", "consumeRequestHash", "consumedAt", "usedCount", "maxUsage"],
      "properties": {
        "slot": { "type": "integer", "minimum": 0, "maximum": 99 },
        "idempotencyKeyHash": { "type": "string", "pattern": "^[0-9a-fA-F]{64}$" },
        "consumeRequestHash": { "type": "string", "pattern": "^[0-9a-fA-F]{64}$" },
        "consumedAt": { "type": "string", "format": "date-time" },
        "usedCount": { "type": "integer", "minimum": 1, "maximum": 100 },
        "maxUsage": { "type": "integer", "minimum": 1, "maximum": 100 }
      }
    }
  }
}
