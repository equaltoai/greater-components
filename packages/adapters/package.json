{
  "name": "@equaltoai/greater-components-adapters",
  "private": true,
  "version": "0.11.0",
  "type": "module",
  "description": "Transport adapters and state management for Greater Components",
  "license": "AGPL-3.0-only",
  "author": "Greater Contributors",
  "repository": {
    "type": "git",
    "url": "https://github.com/equaltoai/greater-components.git",
    "directory": "packages/adapters"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "vite build && tsc -b --force --emitDeclarationOnly",
    "clean": "rm -rf dist",
    "dev": "vite build --watch",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@apollo/client": "^4.2.3",
    "@apollo/client-react-streaming": "^0.14.5",
    "@graphql-typed-document-node/core": "^3.2.0",
    "graphql": "^16.13.2",
    "graphql-ws": "^6.0.8",
    "viem": "2.53.1"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@vitest/coverage-v8": "^4.1.9",
    "@vitest/ui": "^4.1.9",
    "jsdom": "^29.1.1",
    "svelte": "^5.55.1",
    "typescript": "^6.0.2",
    "vite": "^8.1.0",
    "vitest": "^4.1.9",
    "ws": "^8.21.0"
  },
  "peerDependencies": {
    "svelte": "^5.43.6"
  }
}
